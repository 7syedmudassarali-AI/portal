{
  "entities": {
    "complaints": {
      "title": "Complaint",
      "description": "User complaints regarding services",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "UID of the user who filed the complaint"
        },
        "userEmail": {
          "type": "string",
          "description": "Email address of the user"
        },
        "userName": {
          "type": "string",
          "description": "Display name of the user"
        },
        "title": {
          "type": "string",
          "maxLength": 150,
          "description": "Subject/Title of the complaint"
        },
        "description": {
          "type": "string",
          "maxLength": 1000,
          "description": "Detailed description of the complaint"
        },
        "category": {
          "type": "string",
          "enum": ["quiz", "downloads", "timetable", "other"],
          "description": "Category of the complaint"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "resolved", "closed"],
          "description": "Current status of the complaint"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last updated timestamp"
        }
      },
      "required": [
        "userId",
        "userEmail",
        "userName",
        "title",
        "description",
        "category",
        "status",
        "createdAt",
        "updatedAt"
      ]
    }
  },
  "firestore": {
    "complaints/{complaintId}": {
      "schema": "complaints",
      "description": "User submitted complaints"
    }
  }
}
